u0219i raionul Glodeni.","delight_ranges":[],"image_ranges":[],"inline_style_ranges":[],"aggregated_ranges":[],"ranges":[],"color_ranges":[]},"id":"UzpfSTEwMDA2MzQ4OTU4MjczODpWSzoxNTIzNjYyMjU2Nzk1NjU="},"__module_operation_CometTahoeVideoContextSectionBody_video":{"__dr":"CometTahoeVideoDefaultMessageRenderingStrategy_textWithEntities$normalization.graphql"},"__module_component_CometTahoeVideoContextSectionBody_video":{"__dr":"CometTahoeVideoDefaultMessageRenderingStrategy.react"}},"footer":null,"actor_photo":{"__typename":"CometFeedStoryActorPhotoStrategy","__isICometStorySection":"CometFeedStoryActorPhotoStrategy","is_prod_eligible":true,"story":{"actors":[{"__typename":"User","__isActor":"User","id":"100063489582738","__isEntity":"User","url":"https:\/\/www.facebook.com\/DediuProductions","work_foreign_entity_info":null,"work_info":null,"show_promode_badge":false,"story_bucket":{"nodes":[{"should_show_close_friend_badge":false,"id":"107003861425933","first_story_to_show":null}]},"live_video_for_comet_live_ring":null,"profile_url":"https:\/\/www.facebook.com\/DediuProductions","name":"Dediu Productions","profile_picture":{"uri":"https:\/\/scontent.fkiv7-1.fna.fbcdn.net\/v\/t39.30808-1\/352780936_1674728156287525_2990043441600560257_n.jpg?stp=cp0_dst-jpg_s40x40_tt6&_nc_cat=104&ccb=1-7&_nc_sid=2d3e12&_nc_ohc=kVdMmxC82-oQ7kNvwFCz4eZ&_nc_oc=Adr6fHsvWs4fTRTfpDLJkbH-5VtiBpTO-LpjycDQnLXBeIbT7FqLLSoVpE9OxJ-frC4&_nc_zt=24&_nc_ht=scontent.fkiv7-1.fna&_nc_gid=hv3XZUleVNdkBlGcVkEy3w&oh=00_Af0x_0sMwKdz54EBuKK6pAaVTGZsWMPtnbgitMsuxRG2jg&oe=69F0E157","width":40,"height":40,"scale":1},"is_additional_profile_plus":true,"delegate_page":{"is_business_page_active":false,"id":"1470653502958114"}}],"comet_sections":{"action_link":null},"attachments":[{"action_links":[{"__typename":"MessagePageActionLink"},{"__typename":"MMEMessengerActionLink"}]}],"sponsored_data":null,"id":"UzpfSTEwMDA2MzQ4OTU4MjczODpWSzoxNTIzNjYyMjU2Nzk1NjU="},"has_commerce_attachment":false,"__module_operation_Comet